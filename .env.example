# Copy this to .env.local for local dev, and set the same values
# in Vercel's Project Settings -> Environment Variables for production.

TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=8648521776

# Optional but recommended: protects /api/alert-cron from being triggered
# by anyone who finds the URL. Set this to any random string, and Vercel
# Cron will need to send it as a Bearer token (Vercel does this automatically
# for its own cron jobs when this env var is set).
CRON_SECRET=choose_any_random_string_here
